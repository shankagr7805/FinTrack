{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction (income or expense).",
      "type": "object",
      "properties": {
        "date": {
          "type": "string",
          "format": "date",
          "description": "The date of the transaction (YYYY-MM-DD)."
        },
        "amount": {
          "type": "number",
          "description": "The amount of the transaction."
        },
        "category": {
          "type": "string",
          "description": "The category of the transaction (e.g., Salary, Groceries)."
        },
        "type": {
          "type": "string",
          "enum": ["income", "expense"],
          "description": "The type of transaction."
        },
        "description": {
          "type": "string",
          "description": "A brief description of the transaction."
        },
        "userEmail": {
          "type": "string",
          "format": "email",
          "description": "The email of the user who owns this transaction."
        },
        "uid": {
          "type": "string",
          "description": "The Firebase Auth UID of the owner."
        }
      },
      "required": ["date", "amount", "category", "type", "description", "userEmail", "uid"]
    }
  },
  "firestore": {
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "A collection of all financial transactions."
    }
  }
}
